# Copy to ".env" before running uvicorn locally.
# Defaults match repo-root docker-compose.yml hostnames.

# Postgres — group service gets its own database
# Host-local uvicorn should use localhost:5433 because docker-compose publishes
# postgres_group on host port 5433. Inside Docker use postgres_group:5432.
DATABASE_URL=postgresql+asyncpg://studysync:studysync_dev@localhost:5433/group_db

REDIS_URL=redis://localhost:6379/2

# Kafka — use kafka:29092 inside Docker, localhost:9092 on host
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=group-service
KAFKA_GROUP_EVENTS_TOPIC=GROUP_EVENTS

# MUST match identity_service JWT_SECRET_KEY exactly — shared secret, decode-only
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# Session Service — use http://session_service:8001 inside Docker
SESSION_SERVICE_URL=http://localhost:8001
SESSION_SERVICE_TIMEOUT_SECONDS=5.0
