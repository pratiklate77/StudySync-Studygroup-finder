# Verification Service Configuration

# Database
DATABASE_URL=postgresql+asyncpg://studysync:studysync_dev@postgres_verification:5432/verification_db

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=verification-service
KAFKA_VERIFICATION_EVENTS_TOPIC=VERIFICATION_EVENTS

# Service Settings
MAX_DOCUMENTS_PER_REQUEST=5
ALLOWED_DOCUMENT_TYPES=identity,education,background_check
REDIS_CACHE_TTL_SECONDS=3600
